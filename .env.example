# Server
NODE_ENV=production
PORT=3000
MONGODB_URI=mongodb://mongodb:27017/psicogestion
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend / API
CORS_ORIGIN=http://localhost:3000
VITE_API_URL=http://localhost:3001

# Google Calendar integration
# Credentials (Client ID + Client Secret) are configured per-user through the UI.
# They are stored AES-256 encrypted in MongoDB; no global Google OAuth keys are needed.
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-characters
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google-calendar/callback
