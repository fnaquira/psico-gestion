FROM node:22-alpine

WORKDIR /app

# Copy manifests only (for layer caching)
COPY package.json package-lock.json* ./

# Install all deps including devDependencies
# Using npm to avoid pnpm patch resolution issues in Docker build context
RUN npm install --legacy-peer-deps

EXPOSE 3000 3001

# Default command is overridden by docker-compose
CMD ["npm", "run", "dev"]
